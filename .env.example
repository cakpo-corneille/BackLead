# ======================================================================
# WIFILEAD BACKEND - ENVIRONMENT VARIABLES
# ======================================================================

# ----------------------------------------------------------------------
# 1. CORE DJANGO SETTINGS
# ----------------------------------------------------------------------
# ENVIRONMENT : Peut être "dev" ou "prod"
# Détermine quel fichier de settings sera chargé (config/dev.py ou config/prod.py)
ENVIRONMENT=dev

# DJANGO_SETTINGS_MODULE : Spécifique au déploiement (ex: config.prod)
# Si omis, `config/settings.py` chargera le bon selon ENVIRONMENT
# DJANGO_SETTINGS_MODULE=config.settings

# SECRET_KEY : Clé secrète cryptographique de Django
# À générer aléatoirement pour la production
SECRET_KEY=votre_cle_secrete_hyper_longue_et_aleatoire

# DEBUG : Mode débogage (False en prod)
# En dev, laisser vide ou True
DEBUG=True

# ----------------------------------------------------------------------
# 2. CORS & SECURITY
# ----------------------------------------------------------------------
# ALLOWED_HOSTS : Domaines autorisés séparés par des virgules (prod)
ALLOWED_HOSTS=localhost,127.0.0.1,wifileads-api.onrender.com

# CORS_ALLOWED_ORIGINS : Domaines autorisés pour les requêtes dashboard
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://wifileads-dashboard.vercel.app

# WIDGET_SCRIPT_URL : URL du script widget (utilisé dans les templates)
WIDGET_SCRIPT_URL=http://localhost:8000/static/core_data/widget.js

# ----------------------------------------------------------------------
# 3. DATABASE (POSTGRESQL)
# ----------------------------------------------------------------------
# DATABASE_URL : Chaine de connexion formatée, requise en prod (dj-database-url)
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
# En dev (SQLite), cette variable est facultative.
# DATABASE_URL=postgres://user:password@localhost:5432/wifileads_db

# ----------------------------------------------------------------------
# 4. REDIS & CELERY
# ----------------------------------------------------------------------
# REDIS_URL : Utilisé pour le cache et backend Celery
REDIS_URL=redis://localhost:6379/1

# CELERY_BROKER_URL : Broker des workers Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# CELERY_RESULT_BACKEND : Stockage statuts des workers
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ----------------------------------------------------------------------
# 5. BUSINESS LOGIC (OTP TTLs)
# ----------------------------------------------------------------------
# OTP_TTL : Durée de validité des codes de confirmation email/password (secondes)
OTP_TTL=600

# DOUBLE_OPT_TTL : Durée de validité des codes de double opt-in widget (secondes)
DOUBLE_OPT_TTL=300

# ----------------------------------------------------------------------
# 6. EXTERNAL SERVICES & PROVIDERS
# ----------------------------------------------------------------------
# ----- EMAIL PROVIDER -----
# Fournisseur actif : 'brevo', 'sendgrid', 'mailgun', 'smtp' ou 'console'
EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=contact@votre-domaine.com

# Exemples de clés API (selon le provider choisi)
BREVO_API_KEY=xkeysib-votre_cle_brevo
# SENDGRID_API_KEY=SG.votre_cle_sendgrid
# MAILGUN_API_KEY=key-votre_cle_mailgun
# MAILGUN_SENDER_DOMAIN=mg.votre-domaine.com

# ----- SMS PROVIDER -----
# Fournisseur actif : 'brevo', 'fastermessage', 'hub2' ou 'console'
SMS_PROVIDER=console

# Variables selon le provider
# BREVO_SMS_API_KEY=xkeysib-...
# BREVO_SMS_SENDER_ID=WiFiLead

# FASTERMESSAGE_API_KEY=votre_cle_fastermessage
# FASTERMESSAGE_SENDER_ID=WiFiLead

# HUB2_TOKEN=votre_token_hub2
# HUB2_SENDER_ID=WiFiLead

# ----------------------------------------------------------------------
# 7. SUPERUSER AUTO-CREATION (Prod only)
# ----------------------------------------------------------------------
DJANGO_SUPERUSER_EMAIL=admin@wifileads.com
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!

# ----------------------------------------------------------------------
# 8. SENTRY (Prod only)
# ----------------------------------------------------------------------
# SENTRY_DSN=https://xxxxxxxx@o000000.ingest.sentry.io/000000

# ----------------------------------------------------------------------
# 9. AWS S3 / STORAGE (Prod only)
# ----------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=votre_access_key
# AWS_SECRET_ACCESS_KEY=votre_secret_key
# AWS_STORAGE_BUCKET_NAME=votre_bucket_name
# AWS_S3_REGION_NAME=eu-west-3
